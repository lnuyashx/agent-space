{
  "name": "agent-space",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "bridge:start": "node bridge/server.mjs",
    "bridge:dev": "node --watch bridge/server.mjs",
    "check": "npm run build && node --check src/legacy/canvas-app.js && for file in data/*.js; do node --check \"$file\"; done && npm run check:hitareas",
    "check:hitareas": "bash scripts/check-hitareas.sh"
  },
  "dependencies": {
    "pixi.js": "^8.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
